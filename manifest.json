{
  "manifest_version": 3,
  "name": "Auto Absen By isan",
  "version": "3.6",
  "description": "Ekstensi absen otomatis anti-spam pop-up saat refresh.",
  "permissions": ["storage", "activeTab"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://elearning.bsi.ac.id/absen-mhs/*"],
      "js": ["sweetalert2.all.min.js", "content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["poppins.woff2"],
      "matches": ["https://elearning.bsi.ac.id/*"]
    }
  ],
  "icons": {
    "48": "icon.png"
  }
}
